page {
  background-color: #f5f5f5;
  font-size: 28rpx;
  color: #333;
}

.container {
  min-height: 100vh;
  box-sizing: border-box;
}

.flex {
  display: flex;
}

.flex-center {
  display: flex;
  align-items: center;
  justify-content: center;
}

.flex-between {
  display: flex;
  align-items: center;
  justify-content: space-between;
}

.text-red {
  color: #ff4d4f;
}

.text-green {
  color: #52c41a;
}

.text-gray {
  color: #999;
}