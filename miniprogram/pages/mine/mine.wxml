<view class="container">
  <view class="header">
    <text class="title">我的</text>
  </view>

  <view class="menu-list">
    <view class="menu-item" bindtap="goToSearch">
      <text class="menu-icon">+</text>
      <text class="menu-text">添加基金</text>
      <text class="arrow">></text>
    </view>
  </view>

  <view class="menu-list">
    <view class="menu-item">
      <text class="menu-icon">🔄</text>
      <text class="menu-text">刷新频率</text>
      <picker bindchange="onRefreshIntervalChange" value="{{refreshIndex}}" range="{{refreshOptions}}">
        <text class="picker-value">{{refreshOptions[refreshIndex]}}</text>
      </picker>
    </view>
  </view>

  <view class="menu-list">
    <view class="menu-item">
      <text class="menu-icon">ℹ️</text>
      <text class="menu-text">关于</text>
      <text class="arrow">></text>
    </view>
  </view>

  <view class="fund-count">
    <text>自选基金数量: {{fundCount}} 只</text>
  </view>
</view>