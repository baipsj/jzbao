.header {
  background: #1890ff;
  padding: 30rpx;
  color: #fff;
}

.title {
  font-size: 40rpx;
  font-weight: bold;
}

.menu-list {
  margin-top: 20rpx;
  background: #fff;
}

.menu-item {
  display: flex;
  align-items: center;
  padding: 30rpx;
  border-bottom: 1rpx solid #f5f5f5;
}

.menu-item:last-child {
  border-bottom: none;
}

.menu-icon {
  font-size: 36rpx;
  margin-right: 20rpx;
}

.menu-text {
  flex: 1;
  font-size: 30rpx;
}

.arrow {
  color: #999;
}

.picker-value {
  color: #999;
}

.fund-count {
  text-align: center;
  padding: 40rpx;
  color: #999;
}