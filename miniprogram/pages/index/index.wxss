.header {
  background: #1890ff;
  padding: 30rpx;
  color: #fff;
}

.title {
  font-size: 40rpx;
  font-weight: bold;
}

.last-update {
  display: block;
  font-size: 24rpx;
  margin-top: 10rpx;
  opacity: 0.8;
}

.nav-icons {
  display: flex;
  gap: 20rpx;
}

.nav-icon {
  font-size: 28rpx;
  padding: 10rpx 20rpx;
  background: rgba(255,255,255,0.2);
  border-radius: 30rpx;
}

.empty {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 200rpx 0;
}

.empty-icon {
  font-size: 120rpx;
  margin-bottom: 30rpx;
}

.empty-text {
  color: #999;
  font-size: 32rpx;
  margin-bottom: 40rpx;
}

.add-btn {
  background: #1890ff;
  color: #fff;
  padding: 20rpx 60rpx;
  border-radius: 40rpx;
  font-size: 28rpx;
}

.fund-list {
  padding: 20rpx;
}

.fund-item {
  background: #fff;
  border-radius: 16rpx;
  padding: 30rpx;
  margin-bottom: 20rpx;
  display: flex;
  justify-content: space-between;
  align-items: center;
}

.fund-info {
  flex: 1;
}

.fund-name {
  display: block;
  font-size: 32rpx;
  font-weight: bold;
  margin-bottom: 10rpx;
}

.fund-code {
  color: #999;
  font-size: 24rpx;
}

.fund-value {
  text-align: right;
}

.estimate-value {
  display: block;
  font-size: 36rpx;
  font-weight: bold;
  margin-bottom: 10rpx;
}

.estimate-change {
  font-size: 28rpx;
}

.estimate-change.up {
  color: #ff4d4f;
}

.estimate-change.down {
  color: #52c41a;
}

.refresh-tip {
  text-align: center;
  padding: 30rpx;
  color: #999;
  font-size: 24rpx;
}