.header {
  background: #1890ff;
  padding: 30rpx;
  color: #fff;
}

.fund-title {
  text-align: center;
}

.name {
  display: block;
  font-size: 36rpx;
  font-weight: bold;
  margin-bottom: 10rpx;
}

.code {
  font-size: 26rpx;
  opacity: 0.8;
}

.value-card {
  background: #fff;
  margin: 20rpx;
  padding: 40rpx;
  border-radius: 16rpx;
  text-align: center;
}

.value-card .label {
  color: #999;
  font-size: 26rpx;
  margin-bottom: 20rpx;
}

.value-card .value {
  font-size: 64rpx;
  font-weight: bold;
  margin-bottom: 10rpx;
}

.value-card .value.up {
  color: #ff4d4f;
}

.value-card .value.down {
  color: #52c41a;
}

.value-card .change {
  font-size: 32rpx;
  margin-bottom: 20rpx;
}

.value-card .change.up {
  color: #ff4d4f;
}

.value-card .change.down {
  color: #52c41a;
}

.time {
  color: #999;
  font-size: 24rpx;
}

.info-card {
  background: #fff;
  margin: 20rpx;
  padding: 30rpx;
  border-radius: 16rpx;
}

.info-row {
  display: flex;
  justify-content: space-between;
  padding: 20rpx 0;
  border-bottom: 1rpx solid #f5f5f5;
}

.info-row:last-child {
  border-bottom: none;
}

.info-row .label {
  color: #999;
}

.info-row .value-text {
  font-weight: bold;
}

.action-btn {
  padding: 40rpx 20rpx;
}

.add-btn, .remove-btn {
  width: 100%;
  height: 88rpx;
  line-height: 88rpx;
  border-radius: 44rpx;
  font-size: 32rpx;
  border: none;
}

.add-btn {
  background: #1890ff;
  color: #fff;
}

.remove-btn {
  background: #fff;
  color: #999;
  border: 1rpx solid #ddd;
}